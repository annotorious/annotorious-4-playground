    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "dequal": "^2.0.3",
    "nanoevents": "^9.1.0",
    "nanoid": "^5.1.11",
    "nanostores": "^1.3.0",
    "uuid": "^14.0.0"
  }
