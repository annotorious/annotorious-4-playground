{
  "name": "@annotorious/core",
  "version": "4.0.0-preview",
  "author": "Rainer Simon",
  "license": "BSD-3-Clause",
  "homepage": "https://annotorious.dev",
  "keywords": [
    "annotation",
    "image annotation",
    "data annotation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/annotorious/annotorious.git"
  },
  "bugs": {
    "url": "https://github.com/annotorious/annotorious/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/annotorious-core.cjs",
  "module": "./dist/annotorious-core.mjs",
