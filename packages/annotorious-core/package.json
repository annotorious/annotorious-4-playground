  "scripts": {
    "build": "tsc -b && vite build",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/deep-equal": "^1.0.4",
    "typescript": "^6.0.3",
    "unplugin-dts": "^1.0.2",
